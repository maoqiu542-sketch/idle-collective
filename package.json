{
  "name": "idle-collective",
  "version": "1.0.0",
  "description": "A RimWorld-inspired idle game with desktop pet features",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:server": "tsx server/index.ts",
    "dev:online": "concurrently \"npm run dev:server\" \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "npm run build:renderer && npm run build:electron && npm run build:server",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:server": "tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "sync:config": "node scripts/sync-config.js",
    "art:sync-specs": "node scripts/art-pipeline/sync-specs.js",
    "art:queue": "node scripts/art-pipeline/queue-comfyui-generation.js",
    "art:import": "node scripts/art-pipeline/import-comfyui-output.js",
    "art:review": "node scripts/art-pipeline/review-asset.js",
    "art:review-queue": "node scripts/art-pipeline/list-review-queue.js",
    "art:review-dashboard": "node scripts/art-pipeline/list-review-queue.js && node scripts/art-pipeline/build-review-dashboard.js",
    "art:review-api": "node scripts/art-pipeline/serve-review-api.js",
    "art:review-open": "node scripts/art-pipeline/open-review-dashboard.js",
    "art:ai-review": "node scripts/art-pipeline/ai-review-assets.js",
    "art:review-feedback": "node scripts/art-pipeline/update-review-feedback.js",
    "art:bootstrap": "node scripts/art-pipeline/bootstrap-placeholders.js",
    "art:grass": "node scripts/art-pipeline/generate-procedural-grass.js",
    "art:grass-studies": "node scripts/art-pipeline/generate-grass-studies.js",
    "art:grass-promote": "node scripts/art-pipeline/promote-grass-studies.js",
    "art:local-generate": "node scripts/art-pipeline/generate-local-candidates.js",
    "art:terrain-studies": "node scripts/art-pipeline/generate-terrain-studies.js",
    "art:terrain-studies-r2": "node scripts/art-pipeline/generate-terrain-studies-round2.js",
    "art:terrain-promote": "node scripts/art-pipeline/promote-terrain-studies.js",
    "art:terrain-rollback": "node scripts/art-pipeline/rollback-terrain-studies.js",
    "art:export": "node scripts/art-pipeline/export-approved-assets.js",
    "art:manifest": "node scripts/art-pipeline/sync-runtime-manifest.js",
    "art:staged-export": "node scripts/art-pipeline/export-approved-assets.js --scope=staged",
    "art:staged-manifest": "node scripts/art-pipeline/sync-staged-manifest.js",
    "art:final-review": "node scripts/art-pipeline/finalize-staged-asset.js",
    "art:validate": "node scripts/art-pipeline/validate-assets.js",
    "art:monitor": "node scripts/art-pipeline/monitor-art-pipeline.js",
    "art:monitor-schedule": "node scripts/art-pipeline/register-monitor-task.js",
    "art:monitor-start": "node scripts/art-pipeline/start-monitor-loop.js",
    "art:monitor-stop": "node scripts/art-pipeline/stop-monitor-loop.js",
    "art:comfyui-start": "node scripts/art-pipeline/start-comfyui.js",
    "art:comfyui-check": "node scripts/art-pipeline/check-comfyui.js",
    "art:deepseek-check": "node scripts/art-pipeline/check-deepseek.js",
    "art:session-tick": "node scripts/art-pipeline/monitor-session-tick.js",
    "art:session-start": "node scripts/art-pipeline/start-monitor-session.js",
    "art:session-stop": "node scripts/art-pipeline/stop-monitor-session.js",
    "art:session-status": "node scripts/art-pipeline/show-monitor-session.js",
    "art:build": "npm run art:sync-specs && npm run art:bootstrap && npm run art:export && npm run art:manifest && npm run art:staged-export && npm run art:staged-manifest && npm run art:validate",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src electron server --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "game",
    "idle",
    "electron",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uiohook-napi": "^1.5.5",
    "uuid": "^9.0.0",
    "ws": "^8.20.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "sharp": "^0.34.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.1",
    "vitest": "^1.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.idlecollective.game",
    "productName": "Idle Collective",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "config/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config"
      },
      {
        "from": "scripts",
        "to": "scripts"
      }
    ],
    "win": {
      "target": "dir",
      "sign": false,
      "signAndEditExecutable": false
    }
  }
}
