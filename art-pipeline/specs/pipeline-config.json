{
  "version": "1.0.0",
  "comfyui": {
    "baseUrl": "http://127.0.0.1:8189",
    "outputDir": "D:\\teae\\openclaw\\ComfyUI\\output"
  },
  "monitoring": {
    "intervalMinutes": 10,
    "minimumDurationHours": 8,
