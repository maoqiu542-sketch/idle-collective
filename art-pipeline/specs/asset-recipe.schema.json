{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://idle-collective.local/art-pipeline/asset-recipe.schema.json",
  "title": "Asset Recipes",
  "type": "object",
  "required": ["version", "recipes"],
  "properties": {
    "version": {
      "type": "string"
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "workflow",
          "candidate_count",
          "source_resolution",
          "export_presets",
          "prompt_template"
        ],
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "workflow": { "type": "string" },
          "candidate_count": { "type": "integer", "minimum": 1 },
          "source_resolution": {
            "type": "object",
            "required": ["width", "height"],
            "properties": {
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 }
            }
          },
          "export_presets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "width", "height", "fit"],
              "properties": {
                "name": { "type": "string" },
                "width": { "type": "integer", "minimum": 1 },
                "height": { "type": "integer", "minimum": 1 },
                "fit": { "type": "string" }
              }
            }
          },
          "prompt_template": { "type": "string" },
          "background": { "type": "string" },
          "camera": { "type": "string" }
        }
      }
    }
  }
}
